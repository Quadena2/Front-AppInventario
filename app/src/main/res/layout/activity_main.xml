<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:fitsSystemWindows="true"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Demo Arquitecturas Web"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REST · GraphQL · WebSocket"
        android:textSize="14sp"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnRest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="REST — CRUD Productos"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnGraphQL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="GraphQL — Anti Over-Fetching"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnWebSocket"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WebSocket — Stock en Tiempo Real"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnCategorias"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestión de Categorías"/>

</LinearLayout>